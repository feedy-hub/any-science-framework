<Window x:Class="AnyVoice.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AnyVoice 设置"
        Width="520"
        Height="540"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="常规">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" Text="角色大小" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="ScaleSlider" Width="220" Minimum="50" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="ScaleValue" Width="56" Margin="10,8,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" Text="透明度" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="OpacitySlider" Width="220" Minimum="35" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="OpacityValue" Width="56" Margin="10,8,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" Text="字幕显示时长" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <Slider x:Name="SubtitleDurationSlider" Width="220" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" />
                        <TextBlock x:Name="SubtitleDurationValue" Width="70" Margin="10,8,0,0" />
                    </StackPanel>

                    <CheckBox x:Name="SubtitlesCheckBox" Grid.Row="3" Grid.Column="1" Margin="0,10" Content="显示字幕" />
                    <CheckBox x:Name="SpeechCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,10" Content="启用语音播报" />
                    <CheckBox x:Name="StartWithWindowsCheckBox" Grid.Row="5" Grid.Column="1" Margin="0,10" Content="随 Windows 启动" />
                </Grid>
            </TabItem>

            <TabItem Header="语音">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8" Text="FFmpeg" />
                    <TextBox x:Name="FfmpegPathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8" Text="Whisper" />
                    <TextBox x:Name="WhisperPathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8" Text="模型文件" />
                    <TextBox x:Name="ModelPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,4" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8" Text="麦克风" />
                    <TextBox x:Name="AudioDeviceTextBox" Grid.Row="3" Grid.Column="1" Margin="0,4" />
                    <CheckBox x:Name="HotkeyCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,10" Content="启用 Ctrl+Alt+V 听写热键" />
                    <Button x:Name="DetectVoiceButton"
                            Grid.Row="5"
                            Grid.Column="1"
                            Width="120"
                            Margin="0,10,0,4"
                            HorizontalAlignment="Left"
                            Click="DetectVoice_Click"
                            Content="检测本地工具" />
                    <TextBlock x:Name="VoiceStatusText"
                               Grid.Row="6"
                               Grid.ColumnSpan="2"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#47545E"
                               Text="尚未检测" />
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Margin="0,16,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="88" Margin="0,0,8,0" IsCancel="True" Content="取消" />
            <Button Width="88" IsDefault="True" Click="Save_Click" Content="保存" />
        </StackPanel>
    </Grid>
</Window>
