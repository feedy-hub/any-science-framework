<Window x:Class="AnyVoice.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="AnyVoice Companion"
        Width="240"
        Height="330"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Start / stop dictation" Click="Dictation_Click" />
            <MenuItem Header="Settings" Click="Settings_Click" />
            <Separator />
            <MenuItem Header="Exit" Click="Exit_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="SubtitleBubble"
                Grid.Row="0"
                MaxWidth="220"
                Margin="0,0,0,6"
                Padding="10,8"
                HorizontalAlignment="Center"
                Background="#F2FFFFFF"
                BorderBrush="#260F1F2D"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock x:Name="SubtitleText"
                       MaxWidth="196"
                       Foreground="#17222C"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       automation:AutomationProperties.Name="Companion subtitle" />
        </Border>

        <Grid Grid.Row="1"
              Width="180"
              Height="230"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              automation:AutomationProperties.Name="AnyVoice companion character">
            <Ellipse x:Name="StatusHalo"
                     Width="150"
                     Height="150"
                     VerticalAlignment="Top"
                     Margin="0,12,0,0"
                     Fill="#332D9C8C" />

            <Border x:Name="CharacterBody"
                    Width="104"
                    Height="108"
                    Margin="0,0,0,4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Background="#E75E65"
                    BorderBrush="#29323A"
                    BorderThickness="2"
                    CornerRadius="46,46,20,20" />

            <Grid Width="118"
                  Height="118"
                  Margin="0,24,0,0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">
                <Polygon Points="15,34 27,3 48,28"
                         Fill="#42B6A5"
                         Stroke="#29323A"
                         StrokeThickness="2" />
                <Polygon Points="70,28 91,3 103,34"
                         Fill="#42B6A5"
                         Stroke="#29323A"
                         StrokeThickness="2" />
                <Ellipse x:Name="CharacterFace"
                         Width="104"
                         Height="96"
                         VerticalAlignment="Bottom"
                         Fill="#42B6A5"
                         Stroke="#29323A"
                         StrokeThickness="2" />
                <Ellipse Width="10" Height="14" Margin="-35,18,0,0" Fill="#18252E" />
                <Ellipse Width="10" Height="14" Margin="35,18,0,0" Fill="#18252E" />
                <Border x:Name="CharacterMouth"
                        Width="28"
                        Height="6"
                        Margin="0,55,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="#FFFFFF"
                        CornerRadius="4" />
            </Grid>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,18"
                    Padding="8,3"
                    Background="#E629323A"
                    CornerRadius="4">
                <TextBlock x:Name="StatusText"
                           Foreground="#FFFFFF"
                           Text="IDLE" />
            </Border>
        </Grid>
    </Grid>
</Window>
